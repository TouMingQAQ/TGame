# ============================================
MemoryCaptures/

# Crash reports
sysinfo.txt
*.pidb
*.pidb.meta

# ============================================
# AI tools
# ============================================
.claude/

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.user
*.userosscache
*.suo
*.userprefs

# Visual Studio cache (tracked by Unity, regenerated)
.vs/

