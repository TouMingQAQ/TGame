# ============================================
*.apk
*.aab
*.unitypackage
*.app

# ============================================
# Android
# ============================================
*.jdk
*.gradle/

# ============================================
# Asset meta data — only ignore when the
# corresponding asset is also ignored
# ============================================
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta

# Addressables build cache
[Aa]ssets/[Ss]treaming[Aa]ssets/aa.meta
[Aa]ssets/[Ss]treaming[Aa]ssets/aa/*
